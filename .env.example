# WA Sender — Variables de entorno
# Copia este archivo como .env y rellena los valores reales

# ── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Seguridad JWT ────────────────────────────────────────────────────────────
# IMPORTANTE: Cambia esto por una cadena larga y aleatoria en producción
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# ── Rate limiting ────────────────────────────────────────────────────────────
# Máximo de peticiones al login por IP en 15 minutos
LOGIN_RATE_LIMIT=10
