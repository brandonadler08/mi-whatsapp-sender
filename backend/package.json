{
  "name": "whatsapp-sender-backend",
  "version": "3.1.0",
  "description": "WhatsApp Multi-Session Sender — Backend con autenticación JWT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore data/ server.js",
    "prod": "NODE_ENV=production node server.js",
    "pm2:start": "pm2 start ../ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop wa-sender",
    "pm2:reload": "pm2 reload wa-sender",
    "pm2:logs": "pm2 logs wa-sender",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.2",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5",
    "openai": "^4.28.0",
    "socks-proxy-agent": "^8.0.2",
    "https-proxy-agent": "^7.0.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
